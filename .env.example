# Example configuration for trmnl-nws-weather.
#
# Copy this file to ".env" and edit it for your location:
#     cp .env.example .env          # macOS/Linux
#     Copy-Item .env.example .env   # Windows PowerShell
#
# Every value here is optional -- the defaults render for Intercourse, PA. The
# example below is set for a second city, Boring, Oregon, to show what a real
# configuration looks like. CLI flags (e.g. --lat/--lon) override these, which
# in turn override the built-in defaults.
#
# Input validation
# ----------------
# All values are validated before use.  Invalid values are ignored with a
# warning logged, and the built-in default is used instead.  This means
# misspelled enum values, out-of-range numbers, or malformed URLs will not
# impact the service -- they will simply be rejected and the safe default
# applied.  Ranges and allowed values are noted below each variable.

# --- Location (decimal degrees; must be within NWS coverage: US & territories)
# Latitude:  -90 to 90  |  Longitude: -180 to 180
TRMNL_LATITUDE=45.4318
TRMNL_LONGITUDE=-122.3756

# --- Display ---------------------------------------------------------------
TRMNL_UNITS=imperial        # imperial (F / mph) | metric (C / km/h)
TRMNL_THEME=light           # light (black on white) | dark (white on black)
TRMNL_TIME_FORMAT=12        # 12 | 24

# --- Panel geometry --------------------------------------------------------
# A device preset is the easy option: it picks the panel size and bit depth for
# a known TRMNL model in one go, and overrides the individual width/height/
# bit-depth values below.  Leave it empty to set those yourself.
#   og : TRMNL OG Model (800x480, 2-bit / 4 grey levels)
#   x  : TRMNL X Model  (1872x1404, 4-bit / 16 grey levels)
TRMNL_DEVICE= og            # og | x
#
# Individual panel size in pixels and monochrome grey-ramp bit depth (ignored
# when TRMNL_DEVICE is set).  The default 800x480 / 2-bit matches the TRMNL OG.
# The layout is authored at 800x480 (a 5:3 aspect) and scaled to fit other
# sizes; a panel that is not 5:3 (e.g. the X model's 4:3 1872x1404) keeps the
# content's aspect, centres it, and frames the surrounding whitespace with a
# double-line border so the image still fills the whole display.
#TRMNL_WIDTH=800             # panel width in px  (200–4000)
#TRMNL_HEIGHT=480            # panel height in px (200–4000)
#TRMNL_BIT_DEPTH=2           # grey levels: 1 (B/W) | 2 (4 levels) | 4 (16) | 8

# --- Service behavior ------------------------------------------------------
# All numeric values have enforced ranges; values outside the range are
# rejected and the default is used instead.
TRMNL_REFRESH_SECONDS=1800  # re-render interval (60–86400 seconds)
TRMNL_GRAPH_WINDOW_HOURS=18 # temperature graph time span (1–720 hours)
TRMNL_GRAPH_NOW_POSITION=0.0 # where "now" sits in the graph (0.0–1.0)
TRMNL_FORECAST_HOURS=6      # columns in the bottom forecast strip (1–240)
TRMNL_CACHE_SECONDS=900     # serve a cached image for same coords this long (0–86400)
TRMNL_CLEANUP_AGE_SECONDS=21600 # delete generated PNGs older than this (0–604800)
TRMNL_OUTPUT_DIR=images     # where generated PNGs are written

# --- Air Quality Index (optional) ------------------------------------------
# The NWS feed has no AQI, so it is fetched separately.
#   open-meteo : free, no API key, US EPA AQI for TRMNL_LATITUDE/LONGITUDE (default)
#   none       : disable the AQI box (shows "--")
TRMNL_AQI_PROVIDER=open-meteo
#
# To use a custom source instead (e.g. a local air-quality sensor), point this
# at any endpoint returning JSON like {"aqi": 42}. When set, it overrides the
# provider above. Leave empty to use TRMNL_AQI_PROVIDER.
# Only http:// and https:// schemes are accepted; other schemes are rejected.
TRMNL_AQI_URL=

# --- Webhook (optional) ----------------------------------------------------
# Default destination for "--webhook". When set, you can run "--webhook" with
# no URL on the command line and the image is POSTed here. A URL passed on the
# command line (--webhook https://...) overrides this value.
# Only http:// and https:// schemes are accepted; other schemes are rejected.
TRMNL_WEBHOOK_URL=
